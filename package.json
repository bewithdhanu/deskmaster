{
  "name": "deskmaster",
  "version": "3.3.4",
  "description": "DeskMaster - Master your desktop experience with system monitoring, world clocks, and productivity tools.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder --mac",
    "dist": "electron-builder --mac --publish=never",
    "build-mac": "electron-builder --mac",
    "build-mac-arm64": "npx electron-builder --mac --arm64",
    "build-mac-x64": "npx electron-builder --mac --x64",
    "build-mac-universal": "npx electron-builder --mac --universal",
    "install-deps": "npm install electron systeminformation --save",
    "build-react": "webpack --mode production",
    "dev-react": "webpack serve --mode development",
    "watch": "webpack --mode development --watch",
    "build-app": "node build.js",
    "dev-app": "node dev.js",
    "test-app": "node test-app.js",
    "serve": "node server.js",
    "serve:build": "npm run build-app && node server.js",
    "test:e2e": "playwright test",
    "test:e2e:agent": "playwright test tests/e2e/agent.spec.js",
    "test:unit:agent": "node tests/unit/agentChatStore.test.js"
  },
  "keywords": [
    "desktop-productivity",
    "system-monitor",
    "world-clocks",
    "electron",
    "tray",
    "performance",
    "productivity-tools"
  ],
  "author": {
    "name": "Dhanu K",
    "email": "bewithdhanu@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.22.0",
    "@electron/notarize": "^3.1.1",
    "@playwright/test": "^1.60.0",
    "autoprefixer": "^10.4.21",
    "babel-loader": "^9.1.0",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^6.8.0",
    "electron": "^27.3.11",
    "electron-builder": "^24.6.4",
    "electron-reload": "^2.0.0-alpha.1",
    "html-webpack-plugin": "^5.6.4",
    "postcss": "^8.4.0",
    "postcss-loader": "^7.3.0",
    "style-loader": "^3.3.0",
    "tailwindcss": "^3.3.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^4.15.0"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1068.0",
    "@blocknote/core": "^0.50.0",
    "@blocknote/react": "^0.50.0",
    "@blocknote/shadcn": "^0.50.0",
    "@composio/core": "^0.10.0",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-toggle": "^1.1.10",
    "active-win": "^8.2.1",
    "archiver": "^7.0.1",
    "auto-launch": "^5.0.6",
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.4.0",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "docx": "^9.7.1",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "html2canvas": "^1.4.1",
    "mammoth": "^1.12.0",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.0",
    "monaco-editor": "^0.55.1",
    "monaco-editor-webpack-plugin": "^7.1.1",
    "officeparser": "^7.2.1",
    "otplib": "^12.0.1",
    "pdfkit": "^0.19.1",
    "pptxgenjs": "^4.0.1",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "socket.io-client": "^4.8.3",
    "sqlite3": "^5.1.7",
    "systeminformation": "^5.21.15",
    "ws": "^8.18.3",
    "zod": "^4.4.3"
  },
  "build": {
    "appId": "app.deskmaster",
    "productName": "DeskMaster",
    "directories": {
      "output": "dist"
    },
    "compression": "maximum",
    "removePackageScripts": true,
    "removePackageKeywords": true,
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false,
    "asarUnpack": [],
    "files": [
      "main.js",
      "dist/main.bundle.js",
      "dist/tray.bundle.js",
      "dist/about.bundle.js",
      "dist/*.js",
      "dist/index.html",
      "dist/tray-icon.html",
      "dist/about.html",
      "dist/*.woff",
      "dist/*.woff2",
      "dist/assets/**/*",
      "dist/vs/**/*",
      "config.js",
      "stats.js",
      "history.js",
      "clipboard.js",
      "authenticator.js",
      "uptimeMonitor.js",
      "gdriveBackup.js",
      "notesSearch.js",
      "agentChatStore.js",
      "agentProviders.js",
      "agentOrchestrator.js",
      "agentTools.js",
      "agentKnowledge.js",
      "composioBridge.js",
      "agentHandlers.js",
      "agentHttp.js",
      "textLlmService.js",
      "agentProviderConfig.js",
      "agentMessageFormat.js",
      "agentResponseMedia.js",
      "agentDocumentExtract.js",
      "agentDocumentGenerator.js",
      "agentFileAttach.js",
      "package.json",
      "assets/**/*"
    ],
    "icon": "assets/icons/app-icon-512.png",
    "mac": {
      "category": "public.app-category.utilities",
      "target": {
        "target": "dmg",
        "arch": [
          "arm64",
          "x64"
        ]
      },
      "icon": "assets/icons/app-icon-512.png",
      "artifactName": "DeskMaster-${version}-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": true,
      "identity": "${env.APPLE_IDENTITY}",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": {
        "teamId": "${env.APPLE_TEAM_ID}"
      }
    },
    "afterSign": "build/notarize.js"
  }
}
